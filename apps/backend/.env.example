PORT=3000
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/files_manager
JWT_SECRET=change-me
JWT_EXPIRES_IN=1d

# storage backend: local in development, gcs otherwise
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=storage
GCS_BUCKET=your-bucket
GCS_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=./gcp-sa.json

# upload policy
UPLOAD_MAX_IMAGE_BYTES=26214400
UPLOAD_MAX_PDF_BYTES=52428800
UPLOAD_MAX_OTHER_BYTES=104857600
