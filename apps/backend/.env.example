NODE_ENV=development
PORT=3005
DATABASE_NAME=files_manager
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_PORT=5432
DATABASE_HOST=localhost
JWT_SECRET=change-me
JWT_EXPIRES_IN=1d
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=storage
API_PUBLIC_URL=http://localhost:3005
GCS_BUCKET=filesmanager-bucket
# Comma-separated extra bucket names in the same project (for per-folder assignment by Admins).
# GCS_BUCKET is always allowed; list additional buckets here.
GCS_ALLOWED_BUCKETS=my-team-bucket,finance-uploads
GCS_PROJECT_ID=filesmanager-project
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
UPLOAD_MAX_IMAGE_BYTES=26214400
UPLOAD_MAX_PDF_BYTES=52428800
UPLOAD_MAX_OTHER_BYTES=104857600

# Local storage token configuration
storage.localTokenSecret=local-upload-secret-change-me-in-production
storage.localTokenExpiresIn=15m

# Optional: npm run seed:admin (defaults: admin@localhost / AdminPass123!)
ADMIN_EMAIL=admin@localhost.com
ADMIN_PASSWORD=AdminPass123!
ADMIN_NAME=Administrator
